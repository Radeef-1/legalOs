enum CopilotSender {
  USER
  COPILOT

  @@map("copilot_sender_enum")
}

model AiCopilotSession {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  title          String   @default("محادثة جديدة") @db.VarChar(255)
  contextModule  String?  @map("context_module") @db.VarChar(100)
  caseId         String?  @map("case_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  case         Case?               @relation(fields: [caseId], references: [id], onDelete: SetNull)
  messages     AiCopilotMessage[]

  @@index([organizationId], map: "idx_copilot_sessions_org")
  @@index([userId], map: "idx_copilot_sessions_user")
  @@map("ai_copilot_sessions")
}

model AiCopilotMessage {
  id                   String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sessionId            String        @map("session_id") @db.Uuid
  sender               CopilotSender
  content              String        @db.Text
  intentDetected       String?       @map("intent_detected") @db.VarChar(100)
  executedAction       Json?         @map("executed_action") @db.JsonB
  explainabilityChain  Json?         @map("explainability_chain") @db.JsonB
  userRating           Int?          @map("user_rating")
  feedbackComment      String?       @map("feedback_comment") @db.Text
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz

  session AiCopilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  User    User?            @relation(fields: [userId], references: [id])
  userId  String?          @db.Uuid

  @@index([sessionId], map: "idx_copilot_messages_session")
  @@map("ai_copilot_messages")
}

model AiKnowledgeDoc {
