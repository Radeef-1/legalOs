datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PlanTier {
  solo
  boutique
  enterprise

  @@map("plan_tier_enum")
}

enum OrganizationStatus {
  active
  suspended
  trial

  @@map("organization_status_enum")
}

enum UserStatus {
  active
  inactive

  @@map("user_status_enum")
}

enum CaseType {
  commercial
  labor
  personal_status
  execution

  @@map("case_type_enum")
}

enum CaseStatus {
  open
  in_progress
  resolved
  closed

  @@map("case_status_enum")
}

enum HearingSource {
  manual
  najiz_sync

  @@map("hearing_source_enum")
}

enum DocumentOcrStatus {
  pending
  done
  not_applicable

  @@map("document_ocr_status_enum")
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  overdue
  cancelled

  @@map("invoice_status_enum")
}

enum TimeEntryStatus {
  UNBILLED
  BILLED
  WRITTEN_OFF

  @@map("time_entry_status_enum")
}

enum ExpenseStatus {
  UNBILLED
  BILLED
  REIMBURSED

  @@map("expense_status_enum")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  TRUST_DRAW
  CHEQUE

  @@map("payment_method_enum")
}

enum TrustTransactionType {
  DEPOSIT
  WITHDRAWAL_TO_INVOICE
  REFUND

  @@map("trust_transaction_type_enum")
}

enum HearingStatus {
  SCHEDULED
  COMPLETED
  POSTPONED
  CANCELLED

  @@map("hearing_status_enum")
}

enum CalendarEventType {
  COURT_HEARING
  CLIENT_MEETING
  INTERNAL_MEETING
  LEGAL_DEADLINE
  PERSONAL

  @@map("calendar_event_type_enum")
}

enum CalendarSyncProvider {
  GOOGLE
  OUTLOOK

  @@map("calendar_sync_provider_enum")
}

enum WorkflowTriggerType {
  CASE_CREATED
  HEARING_COMPLETED
  INVOICE_OVERDUE
  DOCUMENT_UPLOADED
  MANUAL

  @@map("workflow_trigger_type_enum")
}

enum WorkflowNodeType {
  CONDITION
  CREATE_TASK
  SEND_NOTIFICATION
  CREATE_HEARING
  GENERATE_INVOICE
  REQUIRE_APPROVAL
  WAIT_DELAY

  @@map("workflow_node_type_enum")
}

enum WorkflowExecutionStatus {
  RUNNING
  WAITING_APPROVAL
  COMPLETED
  FAILED
  CANCELLED

  @@map("workflow_execution_status_enum")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("approval_status_enum")
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
  WHATSAPP
  WEBHOOK

  @@map("notification_channel_enum")
}

enum NotificationType {
  CASE_UPDATED
  HEARING_REMINDER
  INVOICE_ISSUED
  WORKFLOW_APPROVAL_REQUIRED
  TASK_ASSIGNED
  SYSTEM_ALERT

  @@map("notification_type_enum")
}

enum NajizEnv {
  internet
  gsn
  iam

  @@map("najiz_env_enum")
}

enum NajizConnStatus {
  connected
  expired
  failed

  @@map("najiz_conn_status_enum")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED

  @@map("invitation_status_enum")
}

model Organization {
  id                     String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  slug                   String             @unique @db.VarChar(100)
  name                   String             @db.VarChar(255)
  commercialRegistration String?            @map("commercial_registration") @db.VarChar(100)
  unifiedNationalNumber  String?            @map("unified_national_number") @db.VarChar(100)
  planTier               PlanTier           @default(solo) @map("plan_tier")
  status                 OrganizationStatus @default(trial)
  logoUrl                String?            @map("logo_url") @db.VarChar(500)
  faviconUrl             String?            @map("favicon_url") @db.VarChar(500)
  primaryColor           String?            @map("primary_color") @db.VarChar(50)
  secondaryColor         String?            @map("secondary_color") @db.VarChar(50)
  fontFamily             String?            @map("font_family") @db.VarChar(100)
  language               String?            @default("ar") @db.VarChar(10)
  timezone               String?            @default("Asia/Riyadh") @db.VarChar(50)
  dateFormat             String?            @default("YYYY-MM-DD") @map("date_format") @db.VarChar(50)
  currency               String?            @default("SAR") @db.VarChar(10)
  portalDomain           String?            @map("portal_domain") @db.VarChar(255)
  supportEmail           String?            @map("support_email") @db.VarChar(255)
  supportPhone           String?            @map("support_phone") @db.VarChar(50)
  workingHours           String?            @map("working_hours") @db.VarChar(255)
  theme                  String?            @default("light") @db.VarChar(20)
  customCss              String?            @map("custom_css") @db.Text
  settingsJson           Json?              @map("settings_json")
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz

  members                 OrganizationMember[]
  branches                Branch[]
  roles                   Role[]
  clients                 Client[]
  cases                   Case[]
  documents               Document[]
  invoices                Invoice[]
  najizConnections        NajizConnection?
  auditLogs               AuditLog[]
  tasks                   Task[]
  outboxEvents            OutboxEvent[]
  departments             Department[]
  teams                   Team[]
  invitations             WorkspaceInvitation[]
  settings                WorkspaceSetting?
  holidayCalendars        HolidayCalendar[]
  profile                 OrganizationProfile?
  WorkspaceBranding       WorkspaceBranding?
  WorkspaceLocalization   WorkspaceLocalization?
  WorkspacePreference     WorkspacePreference?
  WorkspaceNumbering      WorkspaceNumbering?
  WorkspaceFeatureFlag    WorkspaceFeatureFlag?
  policies                Policy[]
  timeEntries             TimeEntry[]
  expenses                Expense[]
  trustAccounts           TrustAccount[]
  payments                Payment[]
  portalSessions          PortalSession[]
  clientRequests          ClientRequest[]
  WorkspaceStatistic      WorkspaceStatistic?
  hearings                Hearing[]
  calendarEvents          CalendarEvent[]
  calendarSyncCredentials CalendarSyncCredential[]
  workflowDefinitions     WorkflowDefinition[]
  workflowExecutions      WorkflowExecution[]
  workflowApprovals       WorkflowApproval[]
  workflowSlas            WorkflowSla[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  tenantSubscription      TenantSubscription?
  integrationConnections  IntegrationConnection[]
  aiLogs                  AiLog[]
  copilotSessions         AiCopilotSession[]
  copilotKnowledgeDocs    AiKnowledgeDoc[]
  copilotPromptRules      AiCustomPromptRule[]
  portalMessages          PortalMessage[]
  clientActions           ClientAction[]
  portalAppointments      PortalAppointment[]
  portalBranding          PortalBranding?
  portalPermissions       PortalPermission[]
  portalAuditLogs         PortalAuditLog[]
  caseTimelines           CaseTimeline[]

  @@map("organizations")
}

model OrganizationProfile {
  id             String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String  @unique @map("organization_id") @db.Uuid
  address        String? @db.Text
  phone          String? @db.VarChar(50)
  email          String? @db.VarChar(255)
  website        String? @db.VarChar(255)
  taxNumber      String? @map("tax_number") @db.VarChar(100)
  description    String? @db.Text
  logo           String? @db.VarChar(512)
  favicon        String? @db.VarChar(512)
  stamp          String? @db.VarChar(512)
  letterhead     String? @db.VarChar(512)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_profiles")
}

model OrganizationMember {
  id                 String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId     String     @map("organization_id") @db.Uuid
  userId             String     @map("user_id") @db.Uuid
  roleId             String     @map("role_id") @db.Uuid
  branchId           String?    @map("branch_id") @db.Uuid
  departmentId       String?    @map("department_id") @db.Uuid
  employeeNumber     String?    @map("employee_number") @db.VarChar(100)
  jobTitle           String?    @map("job_title") @db.VarChar(255)
  employmentType     String?    @map("employment_type") @db.VarChar(100)
  licenseNumber      String?    @map("license_number") @db.VarChar(100)
  profilePhoto       String?    @map("profile_photo") @db.VarChar(512)
  bio                String?    @db.Text
  signature          String?    @db.Text
  isPrimaryWorkspace Boolean    @default(false) @map("is_primary_workspace")
  status             UserStatus @default(active)
  joinedAt           DateTime   @default(now()) @map("joined_at") @db.Timestamptz
  leftAt             DateTime?  @map("left_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  teamMemberships         TeamMember[]
  teamMemberJoinedBy      TeamMember[]                  @relation("TeamMemberJoinedBy")
  teamMemberRemovedBy     TeamMember[]                  @relation("TeamMemberRemovedBy")
  managedBranches         Branch[]                      @relation("BranchManager")
  managedDepartments      Department[]                  @relation("DepartmentManager")
  personalPreference      OrganizationMemberPreference?
  timeEntries             TimeEntry[]
  expenses                Expense[]
  calendarEvents          CalendarEvent[]
  assignedHearings        Hearing[]
  calendarSyncCredentials CalendarSyncCredential[]
  workflowApprovals       WorkflowApproval[]
  escalatedWorkflowSlas   WorkflowSla[]

  @@unique([organizationId, userId])
  @@index([organizationId], map: "idx_org_members_org")
  @@index([userId], map: "idx_org_members_user")
  @@map("organization_members")
}

model OrganizationMemberPreference {
  id              String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  memberId        String @unique @map("member_id") @db.Uuid
  language        String @default("ar") @db.VarChar(10)
  timezone        String @default("Asia/Riyadh") @db.VarChar(100)
  theme           String @default("light") @db.VarChar(50)
  notifications   Json?  @db.JsonB
  dashboardLayout Json?  @map("dashboard_layout") @db.JsonB
  calendarView    String @default("month") @map("calendar_view") @db.VarChar(50)

  member OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("organization_member_preferences")
}

model User {
  id           String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fullName     String     @map("full_name") @db.VarChar(255)
  email        String     @unique @db.VarChar(255)
  nationalId   String?    @map("national_id") @db.VarChar(100)
  passwordHash String?    @map("password_hash") @db.VarChar(255)
  status       UserStatus @default(active)
  mfaEnabled   Boolean    @default(false) @map("mfa_enabled")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz

  memberships             OrganizationMember[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  cases                   Case[]
  documents               Document[]
  tasks                   Task[]
  invitations             WorkspaceInvitation[]    @relation("InviteeUser")
  WorkspaceInvitation     WorkspaceInvitation[]
  copilotSessions         AiCopilotSession[]
  copilotMessages         AiCopilotMessage[]

  @@map("users")
}

model Branch {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  holidayCalendarId String?  @map("holiday_calendar_id") @db.Uuid
  name              String   @db.VarChar(255)
  city              String   @db.VarChar(100)
  country           String   @default("SA") @db.VarChar(100)
  timezone          String   @default("Asia/Riyadh") @db.VarChar(100)
  address           String?  @db.Text
  phone             String?  @db.VarChar(50)
  email             String?  @db.VarChar(255)
  managerMemberId   String?  @map("manager_member_id") @db.Uuid
  latitude          Decimal? @db.Decimal(9, 6)
  longitude         Decimal? @db.Decimal(9, 6)
  isHeadOffice      Boolean  @default(false) @map("is_head_office")

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  holidayCalendar HolidayCalendar?     @relation(fields: [holidayCalendarId], references: [id], onDelete: SetNull)
  manager         OrganizationMember?  @relation("BranchManager", fields: [managerMemberId], references: [id], onDelete: SetNull)
  members         OrganizationMember[]

  @@index([organizationId], map: "idx_branches_org")
  @@map("branches")
}

model Role {
  id             String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String?               @map("organization_id") @db.Uuid
  name           String                @db.VarChar(100)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz
  organization   Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        OrganizationMember[]
  permissions    RolePermission[]
  invitations    WorkspaceInvitation[]

  @@unique([organizationId, name])
  @@map("roles")
}

model Permission {
  id          String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String           @unique @db.VarChar(100)
  description String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Client {
  id                  String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId      String          @map("organization_id") @db.Uuid
  name                String          @db.VarChar(255)
  nationalIdOrCr      String          @map("national_id_or_cr") @db.VarChar(100)
  phone               String?         @db.VarChar(50)
  email               String?         @db.VarChar(255)
  portalAccessEnabled Boolean         @default(false) @map("portal_access_enabled")
  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cases               Case[]
  invoices            Invoice[]
  expenses            Expense[]
  trustAccounts       TrustAccount[]
  CalendarEvent       CalendarEvent[]
  portalSessions      PortalSession[]
  clientRequests      ClientRequest[]
  portalMessages      PortalMessage[]
  clientActions       ClientAction[]
  portalAppointments  PortalAppointment[]
  portalPermissions   PortalPermission?
  portalAuditLogs     PortalAuditLog[]

  @@index([organizationId], map: "idx_clients_org")
  @@map("clients")
}

model Case {
  id                 String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId     String     @map("organization_id") @db.Uuid
  clientId           String     @map("client_id") @db.Uuid
  assignedLawyerId   String?    @map("assigned_lawyer_id") @db.Uuid
  caseNumberInternal String     @map("case_number_internal") @db.VarChar(100)
  najizCaseNumber    String?    @map("najiz_case_number") @db.VarChar(100)
  caseType           CaseType   @map("case_type")
  courtName          String?    @map("court_name") @db.VarChar(255)
  status             CaseStatus @default(open)
  lastSyncedAt       DateTime?  @map("last_synced_at") @db.Timestamptz
  openedAt           DateTime   @default(now()) @map("opened_at") @db.Timestamptz
  closedAt           DateTime?  @map("closed_at") @db.Timestamptz
  deletedAt          DateTime?  @map("deleted_at") @db.Timestamptz

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  assignedLawyer User?           @relation(fields: [assignedLawyerId], references: [id], onDelete: SetNull)
  hearings       Hearing[]
  documents      Document[]
  invoices       Invoice[]
  tasks          Task[]
  timeEntries    TimeEntry[]
  expenses       Expense[]
  trustAccounts  TrustAccount[]
  CalendarEvent       CalendarEvent[]
  clientRequests      ClientRequest[]
  portalMessages      PortalMessage[]
  clientActions       ClientAction[]
  portalAppointments  PortalAppointment[]
  caseTimelines       CaseTimeline[]
  copilotSessions     AiCopilotSession[]

  @@unique([organizationId, caseNumberInternal])
  @@index([organizationId], map: "idx_cases_org")
  @@index([clientId], map: "idx_cases_client")
  @@map("cases")
}

model Hearing {
  id               String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  caseId           String        @map("case_id") @db.Uuid
  title            String        @db.VarChar(255)
  hearingDate      DateTime      @map("hearing_date") @db.Timestamptz
  endDate          DateTime?     @map("end_date") @db.Timestamptz
  courtName        String?       @map("court_name") @db.VarChar(255)
  courtRoom        String?       @map("court_room") @db.VarChar(100)
  judgeName        String?       @map("judge_name") @db.VarChar(255)
  assignedLawyerId String?       @map("assigned_lawyer_id") @db.Uuid
  status           HearingStatus @default(SCHEDULED)
  source           HearingSource @default(manual)
  meetingUrl       String?       @map("meeting_url") @db.VarChar(512)
  notes            String?       @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime? @map("updated_at") @db.Timestamptz

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case           Case                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignedLawyer OrganizationMember? @relation(fields: [assignedLawyerId], references: [id], onDelete: SetNull)

  @@index([organizationId], map: "idx_hearings_org")
  @@index([caseId], map: "idx_hearings_case")
  @@map("hearings")
}

model CalendarEvent {
  id             String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  title          String            @db.VarChar(255)
  description    String?           @db.Text
  eventType      CalendarEventType @default(CLIENT_MEETING) @map("event_type")
  startTime      DateTime          @map("start_time") @db.Timestamptz
  endTime        DateTime          @map("end_time") @db.Timestamptz
  isAllDay       Boolean           @default(false) @map("is_all_day")
  location       String?           @db.VarChar(255)
  caseId         String?           @map("case_id") @db.Uuid
  clientId       String?           @map("client_id") @db.Uuid
  organizerId    String            @map("organizer_id") @db.Uuid
  attendeeIds    String[]          @default([]) @map("attendee_ids")

  syncGoogleEventId  String? @map("sync_google_event_id") @db.VarChar(255)
  syncOutlookEventId String? @map("sync_outlook_event_id") @db.VarChar(255)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime? @map("updated_at") @db.Timestamptz

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case         Case?              @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client       Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  organizer    OrganizationMember @relation(fields: [organizerId], references: [id], onDelete: Restrict)

  @@index([organizationId], map: "idx_calendar_events_org")
  @@index([organizerId], map: "idx_calendar_events_organizer")
  @@map("calendar_events")
}

model CalendarSyncCredential {
  id                    String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId        String               @map("organization_id") @db.Uuid
  memberId              String               @map("member_id") @db.Uuid
  provider              CalendarSyncProvider
  accessTokenEncrypted  String               @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?              @map("refresh_token_encrypted") @db.Text
  expiresAt             DateTime?            @map("expires_at") @db.Timestamptz
  calendarId            String?              @map("calendar_id") @db.VarChar(255)
  syncEnabled           Boolean              @default(true) @map("sync_enabled")
  lastSyncedAt          DateTime?            @map("last_synced_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member       OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([organizationId, memberId, provider])
  @@map("calendar_sync_credentials")
}

model Document {
  id             String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  caseId         String?           @map("case_id") @db.Uuid
  uploadedBy     String?           @map("uploaded_by") @db.Uuid
  storagePath    String            @map("storage_path") @db.VarChar(512)
  fileType       String            @map("file_type") @db.VarChar(100)
  ocrStatus      DocumentOcrStatus @default(not_applicable) @map("ocr_status")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case         Case?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  uploader     User?        @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([organizationId], map: "idx_documents_org")
  @@index([caseId], map: "idx_documents_case")
  @@map("documents")
}

model TimeEntry {
  id             String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  caseId         String?         @map("case_id") @db.Uuid
  memberId       String          @map("member_id") @db.Uuid
  description    String          @db.Text
  hours          Decimal         @db.Decimal(5, 2)
  hourlyRate     Decimal         @map("hourly_rate") @db.Decimal(10, 2)
  totalAmount    Decimal         @map("total_amount") @db.Decimal(12, 2)
  isBillable     Boolean         @default(true) @map("is_billable")
  status         TimeEntryStatus @default(UNBILLED)
  invoiceId      String?         @map("invoice_id") @db.Uuid
  date           DateTime        @default(now()) @db.Timestamptz

  createdById String?   @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime? @map("updated_at") @db.Timestamptz

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case         Case?              @relation(fields: [caseId], references: [id], onDelete: SetNull)
  member       OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Restrict)
  invoice      Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId], map: "idx_time_entries_org")
  @@index([caseId], map: "idx_time_entries_case")
  @@map("time_entries")
}

model Expense {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  caseId         String?       @map("case_id") @db.Uuid
  clientId       String?       @map("client_id") @db.Uuid
  memberId       String        @map("member_id") @db.Uuid
  category       String        @db.VarChar(100)
  description    String        @db.Text
  amount         Decimal       @db.Decimal(12, 2)
  vatAmount      Decimal       @default(0.00) @map("vat_amount") @db.Decimal(10, 2)
  isBillable     Boolean       @default(true) @map("is_billable")
  status         ExpenseStatus @default(UNBILLED)
  invoiceId      String?       @map("invoice_id") @db.Uuid
  receiptUrl     String?       @map("receipt_url") @db.VarChar(512)
  date           DateTime      @default(now()) @db.Timestamptz

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
