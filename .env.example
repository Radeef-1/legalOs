# ==============================================================================
# LegalOS Enterprise Environment Configuration Template (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# Database & Multi-Tenancy (PostgreSQL + Prisma ORM)
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://legalos_app:app_secure_password@localhost:5432/legalos_dev?schema=public"

# ------------------------------------------------------------------------------
# Redis Cache, Session & Queue Engine (Redis 7)
# ------------------------------------------------------------------------------
REDIS_URL="redis://default:password@localhost:6379"

# ------------------------------------------------------------------------------
# JWT & Security Configuration
# ------------------------------------------------------------------------------
JWT_SECRET="super-secret-key-legalos-production-2026"
PORT=3000

# ------------------------------------------------------------------------------
# Authentica.sa KSA OTP & Biometrics API
# ------------------------------------------------------------------------------
AUTHENTICA_API_KEY="your-authentica-api-key-here"
AUTHENTICA_BASE_URL="https://api.authentica.sa/api/v2"

# ------------------------------------------------------------------------------
# Infobip Messaging Gateway
# ------------------------------------------------------------------------------
INFOBIP_API_KEY="your-infobip-api-key-here"
INFOBIP_BASE_URL="https://pd4138.api.infobip.com"

# ------------------------------------------------------------------------------
# Cloudflare R2 Encrypted Storage Vault
# ------------------------------------------------------------------------------
R2_ACCOUNT_ID="your-r2-account-id-here"
R2_BUCKET="legalos-prod-vault"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_PUBLIC_URL="https://your-r2-public-domain.cloudflarestorage.com"
